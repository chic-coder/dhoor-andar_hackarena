/*
 * Multi-Sensor Air Quality Monitor
 * Outputs: pm1, pm25, pm10, co2, voc
 * Format: pm1:12.345,pm2.5:15.678,pm10:20.123,co2:450,voc:85000
 * Serial: 115200 baud
 * 
 * Health Thresholds based on standard guidelines:
 * - CO2: Safe <800 ppm, Symptoms >1000 ppm, BUZZER >2000 ppm
 * - VOC: Safe >150 iaq , Symptoms <150 iaq, BUZZER >200 iaq
 * - PM1: Safe <10 μg/m³, Symptoms >10 μg/m³
 * - PM2.5: Safe <15 μg/m³, Symptoms >15 μg/m³
 * - PM10: Safe <45 μg/m³, Symptoms >45 μg/m³
 * 
 * Buzzer: Pin 23 - 5s ON, 5s OFF pattern when VOC≥200 or CO2≥2000
 */

#include <Wire.h>
#include <Adafruit_Sensor.h>
#include "Adafruit_BME680.h"
#include <MHZ19.h>

// ZH07 Pins
#define RXD2 4
#define TXD2 5

// MH-Z19E Pins
#define MHZ19_RX_PIN 16
#define MHZ19_TX_PIN 17

// I2C Pins (BME680)
#define SDA_PIN 21
#define SCL_PIN 22

// Buzzer Pin
#define BUZZER_PIN 23

// Health Thresholds
#define CO2_SAFE_MAX 800      //ppm
#define CO2_SYMPTOMS_START 1000
#define CO2_SEVERE_START 2000    // BUZZER TRIGGER
#define CO2_CRITICAL 5000

#define VOC_SAFE_MAX 100     
#define VOC_SYMPTOMS_START 150
#define VOC_SEVERE_START 200     // BUZZER TRIGGER
#define VOC_CRITICAL 300

#define PM1_SAFE_MAX 10      // μg/m³
#define PM1_SYMPTOMS_START 10
#define PM1_MODERATE 25
#define PM1_UNHEALTHY 50

#define PM25_SAFE_MAX 15     // μg/m³
#define PM25_SYMPTOMS_START 15
#define PM25_MODERATE 35
#define PM25_UNHEALTHY 75

#define PM10_SAFE_MAX 45     // μg/m³
#define PM10_SYMPTOMS_START 45
#define PM10_MODERATE 100
#define PM10_UNHEALTHY 250

// UART instances
HardwareSerial zhSerial(2);      // UART2 for ZH07
HardwareSerial mhz19Serial(1);   // UART1 for MH-Z19E

// Sensor objects
Adafruit_BME680 bme;
MHZ19 myMHZ19;

// Sensor data
struct SensorData 
{
  float pm1_0;
  float pm2_5;
  float pm10;
  int co2;
  float voc;      // Gas resistance in Ohms
  float iaq;      // IAQ index (0-500 scale)
} 
data;

// IAQ calculation globals
float hum_reference = 40.0;   // Optimal humidity %
float gas_reference = 250000; // Will be updated on first reading
float hum_score = 0;
float gas_score = 0;

// Timing
unsigned long lastOutputTime = 0;
const unsigned long OUTPUT_INTERVAL = 2000;  // Output every 2 seconds

// Buzzer control
unsigned long buzzerStartTime = 0;
bool buzzerActive = false;
bool buzzerOn = false;
const unsigned long BUZZER_ON_TIME = 5000;   // 5 seconds ON
const unsigned long BUZZER_OFF_TIME = 5000;  // 5 seconds OFF

// ==========================================
// Parse ZH07 Data (32-byte packet format)
// ==========================================
bool parseZH07Packet() 
{
  if (zhSerial.available() >= 32) 
  {
    uint8_t buffer[32];
    
    if (zhSerial.readBytes(buffer, 32) == 32) 
    {
      // Check for header bytes 0x42 0x4D
      if (buffer[0] == 0x42 && buffer[1] == 0x4D) 
      {
        // Extract PM values from packet
        data.pm1_0 = (float)((buffer[4] << 8) | buffer[5]);
        data.pm2_5 = (float)((buffer[6] << 8) | buffer[7]);
        data.pm10 = (float)((buffer[8] << 8) | buffer[9]);
        
        return true;
       }
     }
   }
  
  return false;
}

// ==========================================
// Read MH-Z19E CO2
// ==========================================
void readCO2() 
{
  data.co2 = myMHZ19.getCO2();
  
  // Validate reading
  if (data.co2 < 0 || data.co2 > 5000) 
  {
    data.co2 = 0;  // Invalid reading
  }
}

// ==========================================
// Read BME680 VOC (Gas Resistance) + Compute IAQ
// ==========================================
void readVOC() 
{
  if (bme.performReading()) 
  {
    data.voc = bme.gas_resistance;  // In Ohms
    gas_reference = data.voc;       // Update gas reference for IAQ calc

    // --- Humidity contribution (25% of IAQ score) ---
    float current_humidity = bme.readHumidity();
    if (current_humidity >= 38 && current_humidity <= 42)
      hum_score = 0.25 * 100; // Optimal humidity band
    else
    {
      if (current_humidity < 38)
        hum_score = 0.25 / hum_reference * current_humidity * 100;
      else
        hum_score = ((-0.25 / (100 - hum_reference) * current_humidity) + 0.416666) * 100;
    }

    // --- Gas/VOC contribution (75% of IAQ score) ---
    float gas_lower_limit = 5000;    // Bad air quality limit (Ohms)
    float gas_upper_limit = 50000;   // Good air quality limit (Ohms)
    if (gas_reference > gas_upper_limit) gas_reference = gas_upper_limit;
    if (gas_reference < gas_lower_limit) gas_reference = gas_lower_limit;
    gas_score = (0.75 / (gas_upper_limit - gas_lower_limit) * gas_reference
                 - (gas_lower_limit * (0.75 / (gas_upper_limit - gas_lower_limit)))) * 100;

    // --- Combine into air_quality_score (0-100, where 100 = good) ---
    float air_quality_score = hum_score + gas_score;
    if (air_quality_score > 100) air_quality_score = 100;
    if (air_quality_score < 0)   air_quality_score = 0;

    // --- Map to IAQ 0-500 scale (inverted: 100% quality = IAQ 0, 0% = IAQ 500) ---
    data.iaq = (1.0 - (air_quality_score / 100.0)) * 500.0;
    if (data.iaq > 500) data.iaq = 500;
    if (data.iaq < 0)   data.iaq = 0;
  }
}

// ==========================================
// Check if buzzer should be active
// ==========================================
bool shouldBuzzerActivate() 
{
  return (data.co2 >= CO2_SEVERE_START || data.iaq >= VOC_SEVERE_START);
}

// ==========================================
// Control Buzzer (5s ON, 5s OFF pattern)
// ==========================================
void controlBuzzer() 
{
  bool shouldBeActive = shouldBuzzerActivate();
  
  if (shouldBeActive) 
  {
    if (!buzzerActive) 
    {
      // Start buzzer pattern
      buzzerActive = true;
      buzzerOn = true;
      buzzerStartTime = millis();
      digitalWrite(BUZZER_PIN, HIGH);
      // Serial.println("⚠⚠⚠ BUZZER ACTIVATED - SEVERE AIR QUALITY!");
    } 
    else 
    {
      // Manage 5s ON, 5s OFF pattern
      unsigned long elapsed = millis() - buzzerStartTime;
      
      if (buzzerOn && elapsed >= BUZZER_ON_TIME) 
      {
        // Turn OFF after 5 seconds
        buzzerOn = false;
        buzzerStartTime = millis();
        digitalWrite(BUZZER_PIN, LOW);
      } 
      else if (!buzzerOn && elapsed >= BUZZER_OFF_TIME) 
      {
        // Turn ON after 5 seconds OFF
        buzzerOn = true;
        buzzerStartTime = millis();
        digitalWrite(BUZZER_PIN, HIGH);
      }
    }
  } 
  else 
  {
    // Air is acceptable - turn off buzzer
    if (buzzerActive) 
    {
      buzzerActive = false;
      buzzerOn = false;
      digitalWrite(BUZZER_PIN, LOW);
      // Serial.println("✓ Air quality improved - Buzzer deactivated");
    }
  }
}

// ==========================================
// Output Data in Required Format (3 decimals)
// ==========================================
void outputData() 
{
  Serial.print("co2:");
  Serial.print(data.co2);
  Serial.print(",voc:");
  Serial.print(data.iaq, 1);   // IAQ value (0-500)
  Serial.print(",pm1:");
  Serial.print(data.pm1_0, 3);
  Serial.print(",pm25:");
  Serial.print(data.pm2_5, 3);
  Serial.print(",pm10:");
  Serial.print(data.pm10, 3);
  Serial.println();
  
}

// ==========================================
// SETUP
// ==========================================
void setup() 
{
  // Initialize Serial
  Serial.begin(115200);
  delay(1000);
  
  // Initialize Buzzer
  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);
  
  // Serial.println("Multi-Sensor Air Quality Monitor");
  
  // Initialize ZH07 (PM sensor) - 32-byte packet format
  zhSerial.begin(9600, SERIAL_8N1, RXD2, TXD2);
  
  // Initialize MH-Z19E (CO2 sensor)
  mhz19Serial.begin(9600, SERIAL_8N1, MHZ19_RX_PIN, MHZ19_TX_PIN);
  myMHZ19.begin(mhz19Serial);
  myMHZ19.autoCalibration(true);  // Enable ABC
  
  // Initialize BME680 (VOC sensor)
  Wire.begin(SDA_PIN, SCL_PIN);
  if (!bme.begin(0x76)) 
  {
    if (!bme.begin(0x77)) 
    {
      // BME680 not found - continue anyway
      data.voc = 0;
    }
  }
  
  // Configure BME680
  bme.setTemperatureOversampling(BME680_OS_8X);
  bme.setHumidityOversampling(BME680_OS_2X);
  bme.setPressureOversampling(BME680_OS_4X);
  bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
  bme.setGasHeater(320, 150);
  
  // Initialize sensor data
  data.pm1_0 = 0;
  data.pm2_5 = 0;
  data.pm10 = 0;
  data.co2 = 0;
  data.voc = 0;
  data.iaq = 0;
  
  delay(2000);  // Sensor warm-up
}

// ==========================================
// LOOP
// ==========================================
void loop() 
{
  unsigned long currentTime = millis();
  
  // Continuously parse ZH07 data (32-byte packet)
  parseZH07Packet();
  
  // Control buzzer based on air quality
  controlBuzzer();
  
  // Output data at interval
  if (currentTime - lastOutputTime >= OUTPUT_INTERVAL) 
  {
    lastOutputTime = currentTime;
    
    // Read all sensors
    readCO2();
    readVOC();
    
    // Output in required format (3 decimals for PM values)
    outputData();
  }
  
  delay(10);
}
