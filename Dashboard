    def create_sensor_grid(self, parent):
        """Create grid of sensor readings"""
        grid_frame = tk.Frame(parent, bg="#0a0e27")
        grid_frame.pack(fill=tk.X, pady=(0, 20))
        
        # Configure grid weights for 5 equal columns
        for i in range(5):
            grid_frame.columnconfigure(i, weight=1)
        
        sensors = [
            {'name': 'CO₂', 'key': 'co2', 'unit': 'ppm', 'color': '#66bb6a'},
            {'name': 'VOC', 'key': 'voc', 'unit': 'Index', 'color': '#42a5f5'},
            {'name': 'PM1', 'key': 'pm1', 'unit': 'µg/m³', 'color': "#ff7c6b"},
            {'name': 'PM2.5', 'key': 'pm25', 'unit': 'µg/m³', 'color': '#ff6b9d'},
            {'name': 'PM10', 'key': 'pm10', 'unit': 'µg/m³', 'color': '#ffa726'}
        ]
        
        self.sensor_widgets = {}
        
        for idx, sensor in enumerate(sensors):
            card = self.create_sensor_card(
                grid_frame,
                sensor['name'],
                sensor['key'],
                sensor['unit'],
                sensor['color']
            )
            card.grid(row=0, column=idx, padx=5, pady=5, sticky="nsew")
            
    def create_sensor_card(self, parent, name, key, unit, color):
        """Create individual sensor display card"""
        card = tk.Frame(parent, bg="#1a1f3a", relief=tk.FLAT)
        
        # Header
        header = tk.Frame(card, bg=color, height=4)
        header.pack(fill=tk.X)
        
        # Content
        content = tk.Frame(card, bg="#1a1f3a")
        content.pack(fill=tk.BOTH, expand=True, padx=12, pady=12)
        
        # Sensor name
        tk.Label(
            content,
            text=name,
            font=("Courier New", 11, "bold"),
            bg="#1a1f3a",
            fg="#ffffff"
        ).pack(pady=(0, 5))
        
        # Value display
        value_label = tk.Label(
            content,
            text="---",
            font=("Helvetica Neue", 32, "bold"),
            bg="#1a1f3a",
            fg=color
        )
        value_label.pack(pady=5)
        
        # Unit
        tk.Label(
            content,
            text=unit,
            font=("Courier New", 9),
            bg="#1a1f3a",
            fg="#8892b0"
        ).pack()
        
        # Status indicator
        status_label = tk.Label(
            content,
            text="⬤ GOOD",
            font=("Courier New", 9, "bold"),
            bg="#1a1f3a",
            fg="#66bb6a"
        )
        status_label.pack(pady=(8, 0))
        
        # Store widgets (without trend canvas)
        self.sensor_widgets[key] = {
            'value': value_label,
            'status': status_label,
            'color': color
        }
        
        return card
        
    def create_charts_panel(self, parent):
        """Create charts panel with 3 matplotlib graphs only"""
        charts_frame = tk.Frame(parent, bg="#0a0e27")
        charts_frame.pack(fill=tk.X, pady=(0, 20))
        
        tk.Label(
            charts_frame,
            text="📊 HISTORICAL TRENDS",
            font=("Courier New", 12, "bold"),
            bg="#0a0e27",
            fg="#00ffcc"
        ).pack(pady=(0, 8))
        
        # Configure matplotlib style
        plt.style.use('dark_background')
        
        # Create figure with smaller size - 3 subplots in a row
        self.fig = Figure(figsize=(14, 3.5), facecolor='#0a0e27')
        self.fig.subplots_adjust(left=0.06, right=0.98, top=0.88, bottom=0.15, wspace=0.25)
        
        # Create 1x3 grid of subplots
        self.ax_co2 = self.fig.add_subplot(1, 3, 1)
        self.ax_voc = self.fig.add_subplot(1, 3, 2)
        self.ax_pm_combined = self.fig.add_subplot(1, 3, 3)

        # Style each subplot with smaller fonts
        for ax, title, color in [
            (self.ax_pm_combined, 'Particulate Matter (µg/m³)', '#ff6b9d'),
            (self.ax_co2, 'CO₂ (ppm)', '#66bb6a'),
            (self.ax_voc, 'VOC Resistance (Ω)', '#42a5f5')
        ]:
            ax.set_title(title, color=color, fontweight='bold', fontsize=12)
            ax.set_facecolor('#1a1f3a')
            ax.grid(True, alpha=0.2, linestyle='--', linewidth=0.5)
            ax.tick_params(colors='#8892b0', labelsize=8)
            for spine in ax.spines.values():
                spine.set_color('#2a2f4a')
        
        # Embed matplotlib in tkinter
        self.canvas = FigureCanvasTkAgg(self.fig, master=charts_frame)
        self.canvas.draw()
        self.canvas.get_tk_widget().pack(fill=tk.X, expand=False)
        
    def update_graphs(self):
        """Update all matplotlib graphs with latest data"""
        if len(self.data_history['timestamps']) < 2:
            return
        
        # Get time data
        timestamps = list(self.data_history['timestamps'])
        time_values = [(t - timestamps[0]).total_seconds() / 60 for t in timestamps]  # Minutes from start
        
        # Update PM Combined (PM1, PM2.5, PM10)
        self.ax_pm_combined.clear()
        
        pm1_data = list(self.data_history['pm1'])
        pm25_data = list(self.data_history['pm25'])
        pm10_data = list(self.data_history['pm10'])
        
        self.ax_pm_combined.plot(time_values, pm1_data, color='#ff7c6b', linewidth=2, label='PM1.0', alpha=0.9)
        self.ax_pm_combined.plot(time_values, pm25_data, color='#ff6b9d', linewidth=2, label='PM2.5', alpha=0.9)
        self.ax_pm_combined.plot(time_values, pm10_data, color='#ffa726', linewidth=2, label='PM10', alpha=0.9)
        
        # Add threshold lines for PM2.5 as reference
        self.ax_pm_combined.axhline(y=self.thresholds['pm25']['good'], color='#66bb6a', linestyle='--', alpha=0.4, linewidth=1, label='Good')
        self.ax_pm_combined.axhline(y=self.thresholds['pm25']['moderate'], color='#ffa726', linestyle='--', alpha=0.4, linewidth=1, label='Moderate')
        self.ax_pm_combined.axhline(y=self.thresholds['pm25']['unhealthy'], color='#ff3366', linestyle='--', alpha=0.4, linewidth=1, label='Unhealthy')
        
        self.ax_pm_combined.set_title('Particulate Matter (µg/m³)', color='#ff6b9d', fontweight='bold', fontsize=10)
        self.ax_pm_combined.set_xlabel('Time (min)', color='#8892b0', fontsize=8)
        self.ax_pm_combined.set_ylabel('µg/m³', color='#8892b0', fontsize=8)
        self.ax_pm_combined.legend(loc='upper left', fontsize=7, framealpha=0.3)
        self.ax_pm_combined.set_facecolor('#1a1f3a')
        self.ax_pm_combined.grid(True, alpha=0.2, linestyle='--', linewidth=0.5)
        self.ax_pm_combined.tick_params(colors='#8892b0', labelsize=7)
        
        # Update CO2
        self.ax_co2.clear()
        co2_data = list(self.data_history['co2'])
        self.ax_co2.plot(time_values, co2_data, color='#66bb6a', linewidth=2, label='CO₂')
        self.ax_co2.fill_between(time_values, co2_data, alpha=0.2, color='#66bb6a')
        
        self.ax_co2.axhline(y=self.thresholds['co2']['good'], color='#66bb6a', linestyle='--', alpha=0.5, linewidth=1, label='Good (<800)')
        self.ax_co2.axhline(y=self.thresholds['co2']['moderate'], color='#ffa726', linestyle='--', alpha=0.5, linewidth=1, label='Moderate')
        self.ax_co2.axhline(y=self.thresholds['co2']['unhealthy'], color='#ff3366', linestyle='--', alpha=0.5, linewidth=1, label='Unhealthy')
        
        self.ax_co2.set_title('CO₂ (ppm)', color='#66bb6a', fontweight='bold', fontsize=10)
        self.ax_co2.set_xlabel('Time (min)', color='#8892b0', fontsize=8)
        self.ax_co2.set_ylabel('ppm', color='#8892b0', fontsize=8)
        self.ax_co2.legend(loc='upper left', fontsize=7, framealpha=0.3)
        self.ax_co2.set_facecolor('#1a1f3a')
        self.ax_co2.grid(True, alpha=0.2, linestyle='--', linewidth=0.5)
        self.ax_co2.tick_params(colors='#8892b0', labelsize=7)
        
        # Update VOC (direct - higher is worse)
        self.ax_voc.clear()
        voc_data = list(self.data_history['voc'])
        self.ax_voc.plot(time_values, voc_data, color='#42a5f5', linewidth=2, label='VOC')
        self.ax_voc.fill_between(time_values, voc_data, alpha=0.2, color='#42a5f5')
        
        self.ax_voc.axhline(y=self.thresholds['voc']['good'], color='#66bb6a', linestyle='--', alpha=0.5, linewidth=1, label='Good (<150)')
        self.ax_voc.axhline(y=self.thresholds['voc']['moderate'], color='#ffa726', linestyle='--', alpha=0.5, linewidth=1, label='Moderate')
        self.ax_voc.axhline(y=self.thresholds['voc']['unhealthy'], color='#ff3366', linestyle='--', alpha=0.5, linewidth=1, label='Unhealthy (>350)')
        
        self.ax_voc.set_title('VOC Index ⚠️ Higher = Worse', color='#42a5f5', fontweight='bold', fontsize=10)
        self.ax_voc.set_xlabel('Time (min)', color='#8892b0', fontsize=8)
        self.ax_voc.set_ylabel('Index', color='#8892b0', fontsize=8)
        self.ax_voc.legend(loc='upper right', fontsize=7, framealpha=0.3)
        self.ax_voc.set_facecolor('#1a1f3a')
        self.ax_voc.grid(True, alpha=0.2, linestyle='--', linewidth=0.5)
        self.ax_voc.tick_params(colors='#8892b0', labelsize=7)
        
        # Redraw canvas
        self.canvas.draw()
        
