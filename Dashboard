"""
Air Quality Monitoring Dashboard
Monitors PM2.5, PM10, CO2, and VOC levels from ESP32 sensor via serial port
"""
import tkinter as tk
from tkinter import ttk, messagebox, scrolledtext
import serial
import serial.tools.list_ports
import threading
import time
from datetime import datetime
import json
from collections import deque
import matplotlib
matplotlib.use('TkAgg')
import matplotlib.pyplot as plt
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg
from matplotlib.figure import Figure

class AirQualityDashboard:
    def __init__(self, root):
        self.root = root
        self.root.title("Air Quality Monitor")
        self.root.geometry("1400x900")
        self.root.configure(bg="#0a0e27")
        
        # Serial connection
        self.serial_port = None
        self.is_connected = False
        self.reading_thread = None
        self.should_stop = False
        
        # Data storage
        self.data_history = {
            'pm1': deque(maxlen=100),
            'pm25': deque(maxlen=100),
            'pm10': deque(maxlen=100),
            'co2': deque(maxlen=100),
            'voc': deque(maxlen=100),
            'timestamps': deque(maxlen=100)
        }
        
        # Current values
        self.current_values = {
            'pm1': 0,
            'pm25': 0,
            'pm10': 0,
            'co2': 0,
            'voc': 0
        }
        
        # Alert thresholds
        # Note: VOC is directly proportional - HIGHER value = WORSE air quality
        self.thresholds = {
            'pm1': {'good': 10, 'moderate': 25, 'unhealthy': 50},
            'pm25': {'good': 15, 'moderate': 35, 'unhealthy': 75},
            'pm10': {'good': 45, 'moderate': 100, 'unhealthy': 250},
            'co2': {'good': 800, 'moderate': 2000, 'unhealthy': 5000},
            'voc': {'good': 150, 'moderate': 200, 'unhealthy': 250}  # Inverse: lower = worse
        }
        
        # Alert system
        self.alert_active = False
        self.log_file = "air_quality_log.json"
        
        # UI ready flag
        self.ui_ready = False
        
        self.setup_ui()
        self.ui_ready = True
        self.start_animation()
        
    def setup_ui(self):
        """Create the user interface with scrollable design (both directions)"""
        # Create main canvas with scrollbars
        main_canvas = tk.Canvas(self.root, bg="#0a0e27", highlightthickness=0)
        v_scrollbar = ttk.Scrollbar(self.root, orient="vertical", command=main_canvas.yview)
        h_scrollbar = ttk.Scrollbar(self.root, orient="horizontal", command=main_canvas.xview)
        
        # Create scrollable frame
        scrollable_frame = tk.Frame(main_canvas, bg="#0a0e27")
        scrollable_frame.bind(
            "<Configure>",
            lambda e: main_canvas.configure(scrollregion=main_canvas.bbox("all"))
        )
        
        main_canvas.create_window((0, 0), window=scrollable_frame, anchor="nw")
        main_canvas.configure(
            yscrollcommand=v_scrollbar.set,
            xscrollcommand=h_scrollbar.set
        )
        
        # Pack canvas and scrollbars
        main_canvas.grid(row=0, column=0, sticky="nsew", padx=(20, 0), pady=(20, 0))
        v_scrollbar.grid(row=0, column=1, sticky="ns", pady=(20, 0))
        h_scrollbar.grid(row=1, column=0, sticky="ew", padx=(20, 0), pady=(0, 20))
        
        # Configure grid weights
        self.root.grid_rowconfigure(0, weight=1)
        self.root.grid_columnconfigure(0, weight=1)
        
        # Enable mouse wheel scrolling (vertical)
        def _on_mousewheel(event):
            main_canvas.yview_scroll(int(-1*(event.delta/120)), "units")
        
        # Enable horizontal scrolling with Shift + Mouse wheel
        def _on_shift_mousewheel(event):
            main_canvas.xview_scroll(int(-1*(event.delta/120)), "units")
        
        main_canvas.bind_all("<MouseWheel>", _on_mousewheel)
        main_canvas.bind_all("<Shift-MouseWheel>", _on_shift_mousewheel)
        
        # Use scrollable_frame as parent for all widgets
        main_frame = scrollable_frame
        
        # Header
        self.create_header(main_frame)
        
        # Connection controls
        self.create_connection_panel(main_frame)
        
        # Warning/Alert panel
        self.create_warning_panel(main_frame)
        
        # Sensor readings grid
        self.create_sensor_grid(main_frame)
        
        # Charts (3 graphs only)
        self.create_charts_panel(main_frame)
        
        # Logs and statistics
        self.create_log_panel(main_frame)
        
        # Footer with statistics
        self.create_footer(main_frame)
        
