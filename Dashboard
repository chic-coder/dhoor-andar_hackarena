    def refresh_ports(self):
        """Refresh available serial ports"""
        ports = serial.tools.list_ports.comports()
        port_list = [port.device for port in ports]
        self.port_combo['values'] = port_list
        if port_list:
            self.port_combo.current(0)
            if self.ui_ready:
                self.log_message(f"Found {len(port_list)} port(s)")
        else:
            if self.ui_ready:
                self.log_message("No serial ports found", "warning")
            
    def toggle_connection(self):
        """Toggle serial connection"""
        if not self.is_connected:
            self.connect()
        else:
            self.disconnect()
            
    def connect(self):
        """Connect to serial port"""
        port = self.port_var.get()
        baud = int(self.baud_var.get())
        
        if not port:
            messagebox.showerror("Error", "Please select a port")
            return
            
        try:
            self.serial_port = serial.Serial(port, baud, timeout=1)
            self.is_connected = True
            self.should_stop = False
            
            # Update UI
            self.connect_btn.config(text="DISCONNECT", bg="#ff3366")
            self.status_canvas.itemconfig(self.status_indicator, fill="#00ffcc")
            self.status_label.config(text="CONNECTED", fg="#00ffcc")
            
            # Start reading thread
            self.reading_thread = threading.Thread(target=self.read_serial, daemon=True)
            self.reading_thread.start()
            
            self.log_message(f"Connected to {port} @ {baud} baud", "success")
            
        except Exception as e:
            messagebox.showerror("Connection Error", str(e))
            self.log_message(f"Connection failed: {str(e)}", "error")
            
    def disconnect(self):
        """Disconnect from serial port"""
        self.should_stop = True
        self.is_connected = False
        
        if self.serial_port and self.serial_port.is_open:
            self.serial_port.close()
            
        # Update UI
        self.connect_btn.config(text="CONNECT", bg="#00ffcc")
        self.status_canvas.itemconfig(self.status_indicator, fill="#ff3366")
        self.status_label.config(text="DISCONNECTED", fg="#ff3366")
        
        self.log_message("Disconnected from serial port", "warning")
        
    def read_serial(self):
        """Read data from serial port"""
        while not self.should_stop and self.is_connected:
            try:
                if self.serial_port.in_waiting:
                    line = self.serial_port.readline().decode('utf-8').strip()
                    self.parse_data(line)
            except Exception as e:
                self.log_message(f"Read error: {str(e)}", "error")
                time.sleep(0.1)
                
    def parse_data(self, data_string):
        """
        Parse incoming serial data
        Expected format: JSON string like:
        {"co2": 450, "voc": 120, "pm1": 8.3, "pm25": 12.5, "pm10": 23.4}
        """
        try:
            data = json.loads(data_string)
            
            # Update current values
            for key in ['co2', 'voc', 'pm1', 'pm25', 'pm10']:
                if key in data:
                    value = float(data[key])
                    self.current_values[key] = value
                    self.data_history[key].append(value)
                    
            # Add timestamp
            self.data_history['timestamps'].append(datetime.now())
            
            # Update UI in main thread
            self.root.after(0, self.update_display)
            
        except json.JSONDecodeError:
            # Try alternative format: "PM25:12.5,PM10:23.4,CO2:450,VOC:120"
            try:
                pairs = data_string.split(',')
                for pair in pairs:
                    key, value = pair.split(':')
                    key = key.strip().lower()
                    if key in self.current_values:
                        self.current_values[key] = float(value)
                        self.data_history[key].append(float(value))
                
                self.data_history['timestamps'].append(datetime.now())
                self.root.after(0, self.update_display)
                
            except Exception as e:
                self.log_message(f"Parse error: {data_string}", "error")
                
    def update_display(self):
        """Update all display elements"""
        for key, widgets in self.sensor_widgets.items():
            value = self.current_values[key]
            
            # Update value
            widgets['value'].config(text=f"{value:.1f}")
            
            # Update status
            status = self.get_air_quality_status(key, value)
            widgets['status'].config(
                text=f"⬤ {status['label']}",
                fg=status['color']
            )
            
        # Update matplotlib graphs
        self.update_graphs()
        
        # Update statistics
        self.update_statistics()
        
        # Update data count
        count = len(self.data_history['timestamps'])
        self.data_count_label.config(text=f"Readings: {count}")
        
        # Check for alerts
        self.check_alerts()
        
    def get_air_quality_status(self, sensor, value):
        """Get air quality status based on thresholds"""
        thresholds = self.thresholds[sensor]
        
        # All parameters: higher value = worse air quality
        if value <= thresholds['good']:
            return {'label': 'GOOD', 'color': '#66bb6a'}
        elif value <= thresholds['moderate']:
            return {'label': 'MODERATE', 'color': '#ffa726'}
        elif value <= thresholds['unhealthy']:
            return {'label': 'UNHEALTHY', 'color': '#ff6b9d'}
        else:
            return {'label': 'HAZARDOUS', 'color': '#ff3366'}
            
    def update_statistics(self):
        """Update statistics panel"""
        self.stats_text.delete(1.0, tk.END)
        
        stats = "=== AIR QUALITY STATS ===\n\n"
        
        for key in ['co2', 'voc', 'pm1', 'pm25', 'pm10']:
            data = list(self.data_history[key])
            if data:
                avg = sum(data) / len(data)
                minimum = min(data)
                maximum = max(data)
                current = data[-1]
                
                stats += f"{key.upper()}:\n"
                stats += f"  Current: {current:.1f}\n"
                stats += f"  Average: {avg:.1f}\n"
                stats += f"  Min: {minimum:.1f}\n"
                stats += f"  Max: {maximum:.1f}\n\n"
                
        # Add session info
        if self.data_history['timestamps']:
            duration = datetime.now() - self.data_history['timestamps'][0]
            stats += f"Session Duration:\n  {duration}\n\n"
            stats += f"Total Readings:\n  {len(self.data_history['timestamps'])}\n"
            
        self.stats_text.insert(1.0, stats)
        
    def check_alerts(self):
        """
        Check for threshold violations and trigger alerts with health symptoms
        ⭐ ALERT MESSAGES WITH HEALTH SYMPTOMS ARE GENERATED HERE ⭐
        
        Based on official health guidelines:
        - CO2: Safe 400-800 ppm, Symptoms start 1000-2000 ppm, Dangerous >5000 ppm
        - VOC: Safe 0-0.3 mg/m³, Symptoms 0.3-0.5 mg/m³, Dangerous >1 mg/m³
        - PM1: Safe 0-10 µg/m³, Symptoms 10-25 µg/m³, Dangerous >50 µg/m³
        - PM2.5: Safe 0-15 µg/m³, Symptoms 15-35 µg/m³, Dangerous >75 µg/m³
        - PM10: Safe 0-45 µg/m³, Symptoms 45-100 µg/m³, Dangerous >250 µg/m³
        """
        alerts = []
        suggestions = []
        
        # CO2 (Carbon Dioxide) - Check levels and symptoms
        co2 = self.current_values['co2']
        if co2 > 5000:
            alerts.append(f"🚨 CRITICAL CO2: {co2:.0f} ppm - SEVERE HEADACHE, FATIGUE, BREATHING DIFFICULTY")
            suggestions.append("💡 URGENT: Evacuate room immediately and ventilate thoroughly!")
        elif co2 > 2000:
            alerts.append(f"⚠️ HIGH CO2: {co2:.0f} ppm - Headache, dizziness, increased heart rate")
            suggestions.append("💡 Open all windows and doors immediately for fresh air circulation")
        elif co2 > 1000:
            alerts.append(f"⚠️ ELEVATED CO2: {co2:.0f} ppm - Drowsiness, headache, poor concentration")
            suggestions.append("💡 Increase ventilation - open windows or turn on ventilation system")
        elif co2 <= 800:
            suggestions.append("✓ CO2 levels good - air quality is optimal")
        
        # VOC (Volatile Organic Compounds) - Direct scale (higher = worse)
        voc = self.current_values['voc']
        # Note: VOC index is directly proportional - higher value = worse air quality
        if voc > 350:  # Very high VOC
            alerts.append(f"🚨 CRITICAL VOC: {voc:.0f} - RESPIRATORY IRRITATION, LONG-TERM HEALTH RISKS")
            suggestions.append("💡 URGENT: Identify and remove VOC source, ventilate immediately!")
        elif voc > 250:  # High VOC
            alerts.append(f"⚠️ HIGH VOC: {voc:.0f} - Headache, nausea, dizziness possible")
            suggestions.append("💡 Increase ventilation and identify source of VOCs")
        elif voc > 150:  # Moderate VOC
            alerts.append(f"⚠️ ELEVATED VOC: {voc:.0f} - Mild eye, nose, and throat irritation")
            suggestions.append("💡 Consider opening windows for better air circulation")
        elif voc <= 150:
            suggestions.append("✓ VOC levels good - no irritants detected")
        
        # PM1 (Particulate Matter ≤1 µm)
        pm1 = self.current_values['pm1']
        if pm1 > 50:
            alerts.append(f"🚨 CRITICAL PM1: {pm1:.1f} µg/m³ - LUNG IRRITATION, ASTHMA RISK")
            suggestions.append("💡 URGENT: Use air purifier, avoid outdoor air, keep windows closed")
        elif pm1 > 25:
            alerts.append(f"⚠️ HIGH PM1: {pm1:.1f} µg/m³ - Coughing, breathing discomfort")
            suggestions.append("💡 Use air purifier and reduce physical activity")
        elif pm1 > 10:
            alerts.append(f"⚠️ ELEVATED PM1: {pm1:.1f} µg/m³ - Mild throat irritation")
            suggestions.append("💡 Monitor air quality, consider using air purifier")
        
        # PM2.5 (Particulate Matter ≤2.5 µm)
        pm25 = self.current_values['pm25']
        if pm25 > 75:
            alerts.append(f"🚨 CRITICAL PM2.5: {pm25:.1f} µg/m³ - ASTHMA ATTACKS, LUNG INFLAMMATION")
            suggestions.append("💡 URGENT: Use air purifier, stay indoors, avoid exertion")
        elif pm25 > 35:
            alerts.append(f"⚠️ HIGH PM2.5: {pm25:.1f} µg/m³ - Breathing difficulty, throat irritation")
            suggestions.append("💡 Use HEPA air purifier and limit outdoor exposure")
        elif pm25 > 15:
            alerts.append(f"⚠️ ELEVATED PM2.5: {pm25:.1f} µg/m³ - Eye irritation, coughing")
            suggestions.append("💡 Sensitive individuals should reduce prolonged outdoor activity")
        elif pm25 <= 15:
            suggestions.append("✓ PM2.5 levels good - air quality is healthy")
        
        # PM10 (Particulate Matter ≤10 µm)
        pm10 = self.current_values['pm10']
        if pm10 > 250:
            alerts.append(f"🚨 CRITICAL PM10: {pm10:.1f} µg/m³ - RESPIRATORY PROBLEMS, REDUCED LUNG FUNCTION")
            suggestions.append("💡 URGENT: Everyone should avoid outdoor activities")
        elif pm10 > 100:
            alerts.append(f"⚠️ HIGH PM10: {pm10:.1f} µg/m³ - Coughing, throat irritation")
            suggestions.append("💡 Use air purifier and limit time outdoors")
        elif pm10 > 45:
            alerts.append(f"⚠️ ELEVATED PM10: {pm10:.1f} µg/m³ - Sneezing, eye irritation")
            suggestions.append("💡 Sensitive individuals should take precautions")
        elif pm10 <= 45:
            suggestions.append("✓ PM10 levels good - air quality is satisfactory")
        
        # Post alerts to warning panel
        if alerts:
            # ⭐ ALERTS WITH HEALTH SYMPTOMS APPEAR IN WARNINGS BOX HERE ⭐
            timestamp = datetime.now().strftime("%H:%M:%S")
            for alert in alerts:
                self.add_warning(f"[{timestamp}] {alert}")
            
            # Also log
            if not self.alert_active:
                self.alert_active = True
                alert_msg = "\n".join(alerts)
                self.log_message(f"⚠️ HEALTH ALERT: {alert_msg}", "error")
                self.root.after(5000, lambda: setattr(self, 'alert_active', False))
        
        # Add suggestions (limit to avoid spam)
        if suggestions and len(suggestions) > 0:
            # Only add suggestions occasionally (every 10 readings)
            if len(self.data_history['timestamps']) % 10 == 0:
                for suggestion in suggestions[:3]:  # Limit to 3 suggestions at a time
                    self.add_suggestion(suggestion)
                
    def add_warning(self, message):
        """Add warning message to warning panel"""
        if hasattr(self, 'warnings_text'):
            self.warnings_text.config(state=tk.NORMAL)
            # Clear "no warnings" message if present
            current_text = self.warnings_text.get(1.0, tk.END).strip()
            if "No warnings" in current_text or "Warnings cleared" in current_text:
                self.warnings_text.delete(1.0, tk.END)
            
            self.warnings_text.insert(tk.END, message + "\n")
            self.warnings_text.see(tk.END)
            self.warnings_text.config(state=tk.DISABLED)
    
    def add_suggestion(self, message):
        """
        ⭐ ADD SUGGESTION MESSAGES HERE ⭐
        This method adds suggestion messages to the suggestions panel.
        Call this method with your suggestion text.
        
        Example usage:
            self.add_suggestion("💡 Consider opening a window - CO2 levels are rising")
            self.add_suggestion("💡 Air quality is good - maintain current ventilation")
        """
        if hasattr(self, 'suggestions_text'):
            self.suggestions_text.config(state=tk.NORMAL)
            # Clear initial message if present
            current_text = self.suggestions_text.get(1.0, tk.END).strip()
            if "System ready" in current_text:
                self.suggestions_text.delete(1.0, tk.END)
            
            timestamp = datetime.now().strftime("%H:%M:%S")
            self.suggestions_text.insert(tk.END, f"[{timestamp}] {message}\n")
            self.suggestions_text.see(tk.END)
            self.suggestions_text.config(state=tk.DISABLED)
            
