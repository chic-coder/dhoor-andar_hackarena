    def export_data(self):
        """Export collected data to JSON file"""
        if not self.data_history['timestamps']:
            messagebox.showwarning("No Data", "No data to export")
            return
            
        try:
            export_data = {
                'export_time': datetime.now().isoformat(),
                'session_start': self.data_history['timestamps'][0].isoformat(),
                'session_end': self.data_history['timestamps'][-1].isoformat(),
                'readings': []
            }
            
            for i in range(len(self.data_history['timestamps'])):
                reading = {
                    'timestamp': self.data_history['timestamps'][i].isoformat(),
                    'co2': self.data_history['co2'][i],
                    'voc': self.data_history['voc'][i],
                    'pm1': self.data_history['pm1'][i],
                    'pm25': self.data_history['pm25'][i],
                    'pm10': self.data_history['pm10'][i]
                }
                export_data['readings'].append(reading)
                
            filename = f"air_quality_export_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
            
            with open(filename, 'w') as f:
                json.dump(export_data, f, indent=2)
                
            self.log_message(f"Data exported to {filename}", "success")
            messagebox.showinfo("Success", f"Data exported to:\n{filename}")
            
        except Exception as e:
            messagebox.showerror("Export Error", str(e))
            self.log_message(f"Export failed: {str(e)}", "error")
            
    def start_animation(self):
